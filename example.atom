;start

@str `Hello from ATOM`
@crlf `\r\n`
@buf { 0 0 0 0 0 }

@strlen
[
    "dup
    [
        &load 0 eq not
        [ 1 "add t ]
        [ f ]
        ifte
    ] loop
    "swap "sub
]

@print/s
[
    [
        &load dup 0 eq not
        [ CON out 1 "add t ]
        [ drop f ]
        ifte
    ] loop
    drop
]

@mod
[
    [
        >n >m
        <m <n lt
        [ <m f ]
        [ <m <n sub <n t ]
        ifte
    ] loop
]

@print/b
[
    2
    [
        >i
        dup 10 ;mod! 48 add
        <i ;buf "add poke

        10 div
        <i 0 eq not
        [ <i 1 sub t]
        [ drop f ]
        ifte
    ] loop

    0 3 ;buf "add poke

    ;buf 2
    [
        >n
        <n 0 eq not
        [
            &load 48 eq
            [ "inc <n 1 sub t ]
            [ f ]
            ifte
        ]
        [ f ]
        ifte
    ] loop

    ;print/s!
]

@start

