#!/usr/bin/env janet

# I love me pegs
(def atom-peg (peg/compile ~{
    :main (any (choice :ws :token))
    :ws (some :s)
    :id (some (if-not (set " \t\n\r[]!;{}`\"@><&") 1))
    :token (choice
        :label
        :addrof
        :eval
        :bind
        :fetch
        :string
        :number
        :quote
        :raw
        :wide
        :keep
        :word)
    :label  (replace (sequence "@" (capture :id)) ,(fn [n] [:label n]))
    :addrof (replace (sequence ";" (capture :id)) ,(fn [n] [:addrof n]))
    :bind   (replace (sequence ">" (capture :id)) ,(fn [n] [:bind n]))
    :fetch  (replace (sequence "<" (capture :id)) ,(fn [n] [:fetch n]))
    :eval   (replace "!" ,(fn [] [:builtin :eval]))

    :string (replace (sequence "`" (capture (any (if-not "`" 1))) "`")
                     ,(fn [s] [:string s]))
    :number (replace (capture (some :d)) ,(fn [n] [:number (scan-number n)]))

    :quote (replace (sequence "[" (group (any (choice :ws :token))) "]")
                    ,(fn [children] [:quote children]))
    :raw   (replace (sequence "{" (group (any (choice :ws :number))) "}")
                    ,(fn [numbers] [:raw numbers]))
    :wide  (replace (sequence "\"" :token) ,(fn [tok] [:wide tok]))
    :keep  (replace (sequence "&" :token) ,(fn [tok] [:keep tok]))

    :word  (replace (capture :id) ,(fn [w] [:builtin (keyword w)]))
}))

# KWOOOOOO
# K - keep flag
# W - wide flag
# O - opcode bits

(def flag-wide 0x40)
(def flag-keep 0x80)
(def opcodes @{
    :halt  0x00
    :lit   0x01
    :eval  0x02
    :ret   0x03
    :out   0x04
    :in    0x05
    :dup   0x06
    :swap  0x07
    :nip   0x08
    :drop  0x09
    :rot   0x0a
    :eq    0x0b
    :lt    0x0c
    :gt    0x0d
    :not   0x0e
    :load  0x0f
    :poke  0x10
    :add   0x11
    :sub   0x12
    :mult  0x13
    :div   0x14
    :mod   0x15
    :ifte  0x16
    :loop  0x17
    :tol   0x18
    :froml 0x19
    :dropl 0x20
    :xor   0x21
    :neg   0x22
    :dip   0x23
    :keep  0x24
})

(defn unescape-string [s]
    (string ;(peg/match 
        ~(any (choice
            (sequence "\\" "n" (constant "\n"))
            (sequence "\\" "r" (constant "\r"))
            (sequence "\\" "t" (constant "\t"))
            (sequence "\\" "\\" (constant "\\"))
            (sequence "\\" "\"" (constant "\""))
            (capture 1)
        )) s)
    )
)

(defn assemble [ast]
    (def buf @"")
    (def labl-table @{})
    (defn HERE [] (length buf))

    (defn assemble-node [node &opt flags local-env]
        (default local-env @[])
        (defn find-local [env id]
            (var found nil)
            (for i 0 (length env)
                (if (= (get env i) id) (set found i))
            )
            found
        )

        (default flags 0)

        (match node
        [:wide child] (assemble-node child (bor flags flag-wide))
        [:keep child] (assemble-node child (bor flags flag-keep))

        [:bind id]
        (do
            (buffer/push-byte buf (bor (opcodes :tol) flags))
            (array/push local-env id)
        )

        [:fetch id]
        (if-let [idx (find-local local-env id)]
            (let [offset (- (length local-env) 1 idx)]
                (buffer/push-byte buf (bor (opcodes :lit) flags))
                (buffer/push-byte buf offset)
                (buffer/push-byte buf (bor (opcodes :froml) flags))
            )
            (errorf "undefined local: %s" id)
        )

        [:builtin builtin]
        (let [opcode (opcodes builtin)]
        (if (nil? opcode) (errorf "invalid builtin: %s" builtin))    
        (buffer/push-byte buf (bor opcode flags)))

        [:number n] 
        (if (not= 0 (band flags flag-wide))
        (do
            (buffer/push-byte buf (bor (opcodes :lit) flags)) 
            (buffer/push-uint16 buf :le n))
        (do 
            (buffer/push-byte buf (bor (opcodes :lit) flags)) 
            (buffer/push-byte buf n)))
        [:label labl] (put labl-table labl (HERE))

        [:addrof labl]
        (let [addr (get labl-table labl)]
            (if (nil? addr) (errorf "unbound label: %s" labl))    
            (buffer/push-byte buf (bor (opcodes :lit) flag-wide))
            (buffer/push-uint16 buf :le addr))

        [:quote children] 
        (do
            (def local-top (length local-env))
            (def placeholders @{})
            
            (each child children (match child
                [:quote _] 
                (do
                    (buffer/push-byte buf (bor (opcodes :lit) flag-wide))
                    (put placeholders child {:slot (length buf) :env (array/slice local-env)})
                    (buffer/push-uint16 buf :le 0)) 
                _ (assemble-node child flags local-env)
            ))
            
            (def bound-count (- (length local-env) local-top))
            (repeat bound-count 
                (buffer/push-byte buf (bor (opcodes :dropl) flags)))

            (buffer/push-byte buf (opcodes :ret))
            
            (each child children (match child
                [:quote _]
                (let [addr (length buf)
                      meta (placeholders child)]

                    (assemble-node child flags (meta :env))

                    (let [slot (meta :slot)
                        lo (band addr 0xff)
                        hi (band (brshift addr 8) 0xff)]
                        (put buf slot lo)
                        (put buf (+ slot 1) hi)
                    )
                )
                _ nil
            ))
            
            (while (> (length local-env) local-top) (array/pop local-env))
        )

        [:string str] (do
            (buffer/push-string buf (unescape-string str))
            (buffer/push-byte buf 0)
        )

        [:raw nums] (each num nums (do
            (match num
            [:number n] (assemble-node num)
            _ (errorf "raw buffer can contain only number literals, but %s was found" num)    
            )    
        ))

        _ (errorf "Unknown node %s" node)
    ))

    (match ast
        [[:addrof start] & rest]
        (do
            (buffer/push-uint16 buf :le 0)
            (each node rest (assemble-node node))
            (let [addr (get labl-table start)]
                (if (nil? addr) (errorf "unbound label: %s" start)) 
                (def lo (band addr 0xff))
                (def hi (band (brshift addr 8) 0xff))   
                (put buf 0 lo)
                (put buf 1 hi)
            )
        )
        _ (error "missing reset vector")
    )

    buf
)

(defn emit-c-header []
    (print "#ifndef ATOM_OPCODES_H")
    (print "#define ATOM_OPCODES_H\n")
    
    (print "/* Modifier Flags */")
    (printf "#define ATOM_FLAG_WIDE 0x%02X" flag-wide)
    (printf "#define ATOM_FLAG_KEEP 0x%02X" flag-keep)
    (print "")
    
    (print "/* Virtual Machine Opcodes */")
    (def sorted-ops (sort (pairs opcodes) (fn [a b] (< (last a) (last b)))))
    (each [name val] sorted-ops
        (printf "#define ATOM_OP_%s 0x%02X" (string/ascii-upper name) val))
        
    (print "\n#endif /* ATOM_OPCODES_H */"))

(defn main [& args]
    (unless (> (length args) 1)
        (print "USAGE: atomc COMMAND")
        (os/exit 1)
    )

    (def cmd (array/slice args 1))

    (match cmd
    ["compile" path out] 
    (if-let [contents (slurp path)] (do
        (def ast (peg/match atom-peg contents))
        (def bytecode (assemble ast))
        (spit out bytecode)
    ))

    ["compile" path]
    (if-let [contents (slurp path)] (do
        (def ast (peg/match atom-peg contents))
        (def bytecode (assemble ast))
        (spit "out.quark" bytecode)
    ))

    ["header"] (emit-c-header)

    ["ast" path]
    (if-let [contents (slurp path)] (do
        (def ast (peg/match atom-peg contents))
        (pp ast)
    ))
    )
)
