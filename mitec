#!/usr/bin/env janet

(defn parse-char-literal [raw-char]
  (if (= (length raw-char) 1)
    (raw-char 0)
    (case raw-char
      "\\n" 10
      "\\r" 13
      "\\t" 9
      "\\'" 39
      "\\\"" 34
      "\\\\" 92
      "\\0" 0
      (if (string/has-prefix? "\\x" raw-char)
        (scan-number (string "0" (string/slice raw-char 1)))
        (error (string "Unknown character escape sequence: " raw-char))))))

(def mite-peg (peg/compile ~{
    :main (any (choice :ws :token))
    :ws (some (choice :s (sequence "#" (any (if-not (set "\r\n") 1)))))
    :id (some (if-not (set " \t\n\r[]!;{}`\"@><&#") 1))
    :token (choice
        :label
        :number
        :anon-quote
        :anon-string
        :addrof
        :eval
        :bind
        :fetch
        :string
        :quote
        :raw
        :wide
        :keep
        :true
        :false
        :word)
    :label       (replace (sequence "@" (capture :id)) ,(fn [n] [:label n]))
    :anon-quote  (replace (sequence ";[" (group (any (choice :ws :token))) "]")
                          ,(fn [children] [:anon-quote children]))
    :anon-string (replace (sequence ";`" (capture (any (if-not "`" 1))) "`")
                          ,(fn [s] [:anon-string s]))
    :addrof      (replace (sequence ";" (capture :id)) ,(fn [n] [:addrof n]))
    :bind        (replace (sequence ">" (capture :id)) ,(fn [n] [:bind n]))
    :fetch       (replace (sequence "<" (capture :id)) ,(fn [n] [:fetch n]))
    :eval        (replace "!" ,(fn [] [:builtin :eval]))
    :true        (replace "t" ,(fn [] [:number 1]))
    :false       (replace "f" ,(fn [] [:number 0]))

    :string (replace (sequence "`" (capture (any (if-not "`" 1))) "`")
                     ,(fn [s] [:string s]))

    :num-hex (sequence (opt (set "+-")) "0" (set "xX") (some :h))
    :num-bin (sequence (opt (set "+-")) (choice "0b" "0B") (some (set "01")))
    :num-oct (sequence (opt (set "+-")) (choice "0o" "0O") (some (range "07")))
    :num-dec (sequence (opt (set "+-")) (some :d))
    :number-literal (choice :num-hex :num-bin :num-oct :num-dec)

    :char-escape (sequence "\\" (choice (set "nrt'\"\\0") (sequence "x" :h :h)))
    :char-normal (if-not (set "'\\") 1)
    :char-literal (sequence "'" (capture (choice :char-escape :char-normal)) "'")

    :num-val (replace (capture :number-literal) ,scan-number)
    :char-val (replace :char-literal ,parse-char-literal)

    :val-literal (choice :num-val :char-val)

    :number (replace :val-literal ,(fn [val] [:number val]))

    :quote (replace (sequence "[" (group (any (choice :ws :token))) "]")
                    ,(fn [children] [:quote children]))

    :raw-repeat (replace (sequence :val-literal (any :ws) "*" (any :ws) :val-literal)
                         ,(fn [val cnt] [:repeat val cnt]))
                         
    :raw-single (replace :val-literal 
                         ,(fn [val] [:single val]))
                         
    :raw-file (replace (sequence "`" (capture (any (if-not "`" 1))) "`")
                       ,(fn [path] [:file path]))
                       
    :raw-item (choice :raw-repeat :raw-single :raw-file)
    
    :raw (replace (sequence "{" (group (any (choice :ws :raw-item))) "}")
                  ,(fn [items] [:raw items]))
    :wide  (replace (sequence "\"" :token) ,(fn [tok] [:wide tok]))
    :keep  (replace (sequence "&" :token) ,(fn [tok] [:keep tok]))

    :word  (replace (capture :id) ,(fn [w] [:builtin (keyword w)]))
}))

(def flag-wide 0x40)
(def flag-keep 0x80)
(def opcode-mask 0x3F)
(def opcodes @{
    :halt  0x00 :lit   0x01 :eval  0x02 :ret   0x03 :out   0x04
    :in    0x05 :dup   0x06 :swap  0x07 :nip   0x08 :drop  0x09
    :rot   0x0a :eq    0x0b :lt    0x0c :gt    0x0d :not   0x0e
    :load  0x0f :poke  0x10 :add   0x11 :sub   0x12 :mult  0x13
    :div   0x14 :mod   0x15 :ifte  0x16 :loop  0x17 :tol   0x18
    :froml 0x19 :dropl 0x20 :xor   0x21 :neg   0x22 :dip   0x23
    :keep  0x24 :over  0x25 :here  0x26
})

(defn unescape-string [s]
    (string ;(peg/match 
        ~(any (choice
            (sequence "\\" "n" (constant "\n"))
            (sequence "\\" "r" (constant "\r"))
            (sequence "\\" "t" (constant "\t"))
            (sequence "\\" "\\" (constant "\\"))
            (sequence "\\" "\"" (constant "\""))
            (capture 1)
        )) s)
    )
)

(def macro-extract-peg
  (peg/compile 
    ~(sequence "%def" (some :s) (capture (some :S)) (some :s) (capture (any 1)))))

(def include-peg
  (peg/compile ~(sequence "%include" (some :s) "`" (capture (any (if-not "`" 1))) "`")))

(def tokenize-peg
  (peg/compile 
    ~(any (capture (choice (some :w) (some :W))))))

(defn preprocess [source-text &opt loaded-files current-dir]
    (default loaded-files @{})
    (default current-dir (os/cwd))
    (def defs @{})
    (def output-lines @[])

    (each line (string/split "\n" source-text)
        (def trimmed (string/triml line))

        (cond

        (string/has-prefix? "%include" trimmed)
        (if-let [[file-path] (peg/match include-peg trimmed)]
            (do (unless (get loaded-files file-path)
                (put loaded-files file-path true)
                (def resolved-path
                    (if (string/has-prefix? "/" file-path)
                        file-path
                        (string current-dir "/" file-path))
                )
                (if-let [lib-source (slurp resolved-path)]
                (do
                    (def path-parts (string/split "/" resolved-path))
                    (def include-dir (string/join (array/slice path-parts 0 (- (length path-parts) 1)) "/"))
                    (def original-dir (os/cwd))
                    (os/cd include-dir)
                    (array/push output-lines (preprocess lib-source loaded-files include-dir))
                    (os/cd original-dir))
                (errorf "Could not read included file: %s" resolved-path))
            ))
            
            (errorf "Malformed include directive: %s" line)
        )

        (string/has-prefix? "%def" trimmed)
        (if-let [[name body] (peg/match macro-extract-peg trimmed)]
            (put defs name (string/trimr body)))
        
        (empty? defs)
        (array/push output-lines line)
        
        :else
        (let [chunks (peg/match tokenize-peg line)
                processed-chunks (map (fn [chunk] (or (get defs chunk) chunk)) chunks)
                processed-line (string/join processed-chunks)]
            (array/push output-lines processed-line)
        )
        )
    )

    (string/join output-lines "\n")
)

(defn assemble [ast]
    (def buf @"")
    (def labl-table @{})
    (def deferred @[]) 
    (defn HERE [] (length buf))

    (defn find-local [env id]
        (var found nil)
        (for i 0 (length env) (if (= ((get env i) :id) id) (set found i)))
        found
    )
    (defn bytes-above [env idx]
        (var sum 0)
        (for i (+ idx 1) (length env) (set sum (+ sum ((get env i) :width))))
        sum
    )
    (defn scope-byte-width [env from]
        (var sum 0)
        (for i from (length env) (set sum (+ sum ((get env i) :width))))
        sum
    )

    (defn assemble-node [node &opt flags local-env]
        (default local-env @[])
        (default flags 0)

        (match node
        [:wide child] (assemble-node child (bor flags flag-wide) local-env)
        [:keep child] (assemble-node child (bor flags flag-keep) local-env)

        [:bind id]
        (do
            (def width (if (not= 0 (band flags flag-wide)) 2 1))
            (buffer/push-byte buf (bor (opcodes :tol) flags))
            (array/push local-env {:id id :width width})
        )

        [:fetch id]
        (if-let [idx (find-local local-env id)]
            (let [entry (get local-env idx)
                  wants-wide (not= 0 (band flags flag-wide))
                  is-wide (= (entry :width) 2)]
                (unless (= wants-wide is-wide)
                    (errorf "local '%s' was bound as %s but fetched as %s"
                            id (if is-wide "wide" "narrow") (if wants-wide "wide" "narrow")))
                (buffer/push-byte buf (bor (opcodes :froml) flags))
                (buffer/push-byte buf (bytes-above local-env idx))
            )
            (errorf "undefined local: %s" id)
        )

        [:builtin builtin]
        (let [opcode (opcodes builtin)]
            (if (nil? opcode) (errorf "invalid builtin: %s" builtin))    
            (buffer/push-byte buf (bor opcode flags))
        )

        [:number n] 
        (if (not= 0 (band flags flag-wide))
            (do (buffer/push-byte buf (bor (opcodes :lit) flags)) (buffer/push-uint16 buf :le n))
            (do (buffer/push-byte buf (bor (opcodes :lit) flags)) (buffer/push-byte buf n))
        )

        [:label labl] (put labl-table labl (HERE))

        [:addrof labl]
        (let [addr (get labl-table labl)]
            (if (nil? addr) (errorf "unbound label: %s" labl))    
            (buffer/push-byte buf (bor (opcodes :lit) flag-wide))
            (buffer/push-uint16 buf :le addr)
        )

        [:anon-quote children]
        (do
            (buffer/push-byte buf (bor (opcodes :lit) flag-wide))
            (def slot (length buf))
            (buffer/push-uint16 buf :le 0)
            (array/push deferred {:type :quote :children children :slot slot :env (array/slice local-env) :flags flags})
        )

        [:anon-string str]
        (do
            (buffer/push-byte buf (bor (opcodes :lit) flag-wide))
            (def slot (length buf))
            (buffer/push-uint16 buf :le 0)
            (array/push deferred {:type :string :str str :slot slot})
        )

        [:quote children] 
        (do
            (def local-top (length local-env))
            (each child children 
                (assemble-node child flags local-env))
            
            (def bound-bytes (scope-byte-width local-env local-top))
            (when (> bound-bytes 0)
                (buffer/push-byte buf (bor (opcodes :dropl) flags))
                (buffer/push-byte buf bound-bytes)
            )
            (buffer/push-byte buf (opcodes :ret))
            (while (> (length local-env) local-top) (array/pop local-env))
        )

        [:string str] 
        (do
            (buffer/push-string buf (unescape-string str))
            (buffer/push-byte buf 0))

        [:raw items] 
        (each item items 
            (match item
                [:single n] 
                (buffer/push-byte buf n)
                
                [:repeat val cnt] 
                (loop [_ :range [0 cnt]] 
                    (buffer/push-byte buf val))
                    
                [:file path]
                (if-let [data (slurp path)]
                    (buffer/push-string buf data)
                    (errorf "Could not read binary file: %s" path))
                    
                _ (errorf "Raw buffer can only contain numbers, repeats, or file paths, but got: %s" item)))

        _ (errorf "Unknown node %s" node)
        )
    )

    (match ast
        [[:addrof start] & rest]
        (do
            (buffer/push-uint16 buf :le 0)
            (each node rest (assemble-node node))
            
            (buffer/push-byte buf (opcodes :halt)) 
            
            (var idx 0)
            (while (< idx (length deferred))
                (def item (get deferred idx))
                (set idx (+ idx 1))
                
                (def target-addr (HERE))
                (let [lo (band target-addr 0xff)
                      hi (band (brshift target-addr 8) 0xff)]
                    (put buf (item :slot) lo)
                    (put buf (+ (item :slot) 1) hi))
                
                (match (item :type)
                    :string 
                    (do
                        (buffer/push-string buf (unescape-string (item :str)))
                        (buffer/push-byte buf 0))
                    :quote
                    (do
                        (def local-top (length (item :env)))
                        (each child (item :children) 
                            (assemble-node child (item :flags) (item :env)))
                        (def bound-bytes (scope-byte-width (item :env) local-top))
                        (when (> bound-bytes 0)
                            (buffer/push-byte buf (bor (opcodes :dropl) (item :flags)))
                            (buffer/push-byte buf bound-bytes)
                        )
                        (buffer/push-byte buf (opcodes :ret))
                    )
                )
            )

            (let [addr (get labl-table start)]
                (if (nil? addr) (errorf "unbound entry label: %s" start)) 
                (put buf 0 (band addr 0xff))
                (put buf 1 (band (brshift addr 8) 0xff))
            )
        )
        _ (error "missing reset vector"))
    buf
)

(defn emit-c-header []
    (print "#ifndef MITE_OPCODES_H\n#define MITE_OPCODES_H\n")
    (print "/* Modifier Flags */")
    (printf "#define MITE_FLAG_WIDE 0x%02X" flag-wide)
    (printf "#define MITE_FLAG_KEEP 0x%02X" flag-keep)
    (printf "#define MITE_OPCODE_MASK 0x%02X\n" opcode-mask)
    (print "/* Virtual Machine Opcodes */")
    (def sorted-ops (sort (pairs opcodes) (fn [a b] (< (last a) (last b)))))
    (each [name val] sorted-ops (printf "#define MITE_OP_%s 0x%02X" (string/ascii-upper name) val))
    (print "\n#endif /* MITE_OPCODES_H */")
)

(defn file-dir [path]
    (def path-parts (string/split "/" (os/realpath path)))
    (string/join (array/slice path-parts 0 (- (length path-parts) 1)) "/")
)

(defn compile-mite [path &opt out-path]
    (default out-path "out.mbc")
    (if-let [c (slurp path)]
        (spit out-path (assemble (peg/match mite-peg (preprocess c nil (file-dir path)))))
    )
)

(defn main [& args]
    (unless (> (length args) 1) (print "USAGE: mitec COMMAND") (os/exit 1))
    (def cmd (array/slice args 1))
    (match cmd
        ["compile" path out] (compile-mite path out)
        ["compile" path]     (compile-mite path)
        ["header"]           (emit-c-header)
        ["ast" path]         (if-let [c (slurp path)]
            (pp (peg/match mite-peg (preprocess c nil (file-dir path)))))
        ["pp" path]          (if-let [c (slurp path)]
            (pp (preprocess c nil (file-dir path))))
    )
)
